# Copy this file to .env and adjust the values. Docker Compose reads .env automatically.
# .env is gitignored because it holds the root password — never commit it.

# --- MinIO image ---
# For production, pin a specific release tag instead of :latest,
# e.g. quay.io/minio/aistor/minio:RELEASE.2025-08-21T02-50-21Z
MINIO_IMAGE=quay.io/minio/aistor/minio:latest

# --- Root credentials (CHANGE BEFORE DEPLOYING) ---
MINIO_ROOT_USER=minioadmin
# Set a strong password. Generate one with:  openssl rand -base64 24
MINIO_ROOT_PASSWORD=

# --- Public hostnames (create DNS records pointing at the server for both) ---
MINIO_API_DOMAIN=data.simovilab.org
MINIO_CONSOLE_DOMAIN=console.data.simovilab.org

# --- Traefik integration (must match your existing Traefik setup) ---
TRAEFIK_NETWORK=traefik-proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
